# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Google BigQuery ──────────────────────────────────────────────────────────
# Stringified service account JSON:  echo $(cat key.json) | tr -d '\n'
BQ_PROJECT_ID=your-gcp-project-id
BQ_DATASET=bkk_analytics
BQ_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ── Google Earth Engine (Next.js API routes — live GEE tile serving) ─────────
GEE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GEE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GEE_PROJECT_ID=your-gcp-project-id

# ── Cloudflare R2 (satellite data product cache) ─────────────────────────────
# Create an R2 bucket and an API token with Object Read & Write permissions.
# Account ID is found on the R2 overview page in the Cloudflare dashboard.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_api_token_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_api_token_secret_access_key
R2_BUCKET=your-r2-bucket-name
# Public URL of the bucket (enable public access in Cloudflare dashboard):
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxx.r2.dev
# Or if using a custom domain:
# R2_PUBLIC_BASE_URL=https://static.yoursite.com

# ── Satellite cache options ──────────────────────────────────────────────────
SATELLITE_CACHE_PREFIX=satellite-cache
# Set to "true" to reprocess a period even if it already exists in R2
FORCE_REPROCESS=false
# Set to "true" to allow GEE live tile fallback when cache is unavailable
ENABLE_GEE_LIVE_FALLBACK=false

# ── GEE service account for Python processing scripts ────────────────────────
# Full content of your service account JSON key file (used by process-monthly.py
# and process-yearly.py).  In GitHub Actions set this as a repository secret.
# Local usage:  export GEE_SERVICE_ACCOUNT_JSON=$(cat path/to/key.json)
GEE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
